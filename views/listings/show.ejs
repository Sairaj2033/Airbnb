<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-3">
    
 <h3><%= listing.title %> :</h3>
 </div>

    <div class="card col-6 offset-3 show-card">
  <img src="<%=listing.image%>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text"> <br>
         <%= listing.description%> <br>
          &#8377; <%= listing.price.toLocaleString("en-IN")%> <br>
          <%= listing.location %> <br>
          <%= listing.country%> 

    </p>
  </div>
  </div>
  <br>

  <div class="btns">
  <a href="/listings/<%= listing._id%>/edit" class="btn col-1 btn1 offset-3 btn-dark">Edit</a>
<br><br>

 <form method="post" action="/listings/<%=listing._id%>?_method=DELETE"> 
    <button class="btn  delete-btn btn2 offset-5 btn-dark">Delete Permenantly</button>
 </form>
  </div>
  </div>





   <hr>

 <div style="margin-left: 20rem";  class="mb-3">

   <h4>Leave a Review</h4>
    <div class="mb-3 mt-3"> 
   <form >
   <label for="rating"  class="form-label">Rating</label>
   <input  class="form-range" type="range" min="1" max="5" id="rating" name="review[rating]"  >
   </form> 
  </div>

  </div>

  <div  class="mb-3 mt-3" style="margin-left: 20rem;">
     <label for="comment"  class="form-label" >Comments</label>
     <textarea   class="form-control"  name="review[comment]" id="comment" cols="10" rows="5"></textarea>
  </div>

  <button class="btn btn-outline-dark " style="margin-left: 20rem;">Submit </button>

  </div>
<br><br>

 //class=" offset-3"



