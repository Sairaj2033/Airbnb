 <br>

<div >
   <h5 style="display: inline !important;"> <b>Popular homes nearby</b></h5>  <img   src="/images/right-arrow.png" style="height: 1.8rem;display: inline; margin-left: 0.4rem;" alt=""></h4>
</div>

<br>



<div  class="row row-cols-lg-6 row-cols-md-3 row-cols-sm-2 row-cols-2">
     <% for(let listing of  allListings) { %>
<a  class="card-a" href="/listings/<%= listing._id %>">        
<div class=" card lisitng-card" >


  <img src="<%=listing.image.url%>" class="card-img" alt="listing_image" style="aspect-ratio: 1/1; object-fit: cover; width: 100%;"/>

  <div class="card-img-overlay"></div>


  <div style="font-size:85%;" class="card-body">
    <p class="card-text">
       <b><%=listing.title %></b> <br>
          &#8377; <%= listing.price.toLocaleString("en-IN")%>/night  
    </p>
  </div> 
</div>

</a>
<% } %>
</div>



